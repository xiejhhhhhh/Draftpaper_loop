{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paper-fetch-skill.local/schemas/provider-onboarding-review.v2.json",
  "title": "ProviderOnboardingReview v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provider",
    "reviewed_at",
    "fixtures"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "provider": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewed_by": {
      "type": "string"
    },
    "final_markdown_quality_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirmed",
        "confirmed_by",
        "confirmed_at",
        "method",
        "fixture_count",
        "fresh_markdown_quality_reports"
      ],
      "properties": {
        "confirmed": {
          "const": true
        },
        "confirmed_by": {
          "type": "string",
          "minLength": 1
        },
        "confirmed_at": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "const": "final-markdown-quality-review"
        },
        "fixture_count": {
          "type": "integer",
          "minimum": 1
        },
        "fresh_markdown_quality_reports": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fixture_review"
      }
    }
  },
  "$defs": {
    "doi": {
      "type": "string",
      "pattern": "^10\\.[^\\s/]+/.+"
    },
    "fixture_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture",
        "purpose",
        "doi",
        "baseline_markdown_path",
        "baseline_markdown_sha256",
        "markdown_quality_path",
        "markdown_quality_sha256",
        "review_notes",
        "sample_representative",
        "markdown_semantic_reviewed",
        "issues",
        "assertions",
        "fixes"
      ],
      "properties": {
        "fixture": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "doi": {
          "$ref": "#/$defs/doi"
        },
        "baseline_markdown_path": {
          "type": "string",
          "pattern": "^tests/fixtures/(?:golden_criteria|block)/.+/extracted\\.md$"
        },
        "baseline_markdown_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "markdown_quality_path": {
          "type": "string",
          "pattern": "^tests/fixtures/(?:golden_criteria|block)/.+/markdown-quality\\.json$"
        },
        "markdown_quality_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "review_notes": {
          "type": "string",
          "minLength": 1
        },
        "sample_representative": {
          "type": "boolean"
        },
        "markdown_semantic_reviewed": {
          "type": "boolean"
        },
        "issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/review_issue"
          }
        },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fixes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/review_fix"
          }
        }
      }
    },
    "review_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "summary"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stable_id"
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review_fix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "issue_ids",
        "summary",
        "test_names"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stable_id"
        },
        "issue_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stable_id"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "test_names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^test_[A-Za-z0-9_]+$"
          }
        }
      }
    },
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    }
  }
}
