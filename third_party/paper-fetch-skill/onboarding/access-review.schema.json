{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paper-fetch-skill.local/schemas/provider-access-review.v1.json",
  "title": "ProviderAccessReview v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provider",
    "status",
    "reviewed_at",
    "reviewed_by",
    "legal_access",
    "allowed_runtimes",
    "forbidden_behaviors",
    "challenge_policy",
    "site_temporary_policy",
    "may_continue"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "provider": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "status": {
      "enum": ["approved", "blocked"]
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewed_by": {
      "type": "string",
      "minLength": 1
    },
    "legal_access": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "evidence"],
      "properties": {
        "mode": {
          "enum": [
            "public_open_access",
            "institutional_subscription",
            "operator_provided_credentials",
            "metadata_only",
            "blocked"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "allowed_runtimes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["http", "playwright", "browser", "none"]
      }
    },
    "forbidden_behaviors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "challenge_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["captcha", "access_challenge", "rate_limit"],
      "properties": {
        "captcha": {
          "type": "string",
          "minLength": 1
        },
        "access_challenge": {
          "type": "string",
          "minLength": 1
        },
        "rate_limit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "site_temporary_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "expires_at"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "may_continue": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "approved"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "may_continue": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "blocked"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "may_continue": {
            "const": false
          }
        }
      }
    }
  ]
}
