{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paper-fetch-skill.local/schemas/provider-manifest.v1.json",
  "title": "ProviderManifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "display_source",
    "generation",
    "routing",
    "main_path",
    "route_contract",
    "markdown_contract",
    "success_criteria",
    "asset_profile",
    "asset_contract",
    "supplementary_scope",
    "abstract_only_strategy",
    "probe",
    "fixtures",
    "extraction_hints",
    "owner_reuse_exceptions",
    "docs"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "name": {
      "$ref": "#/$defs/provider_name"
    },
    "display_source": {
      "$ref": "#/$defs/provider_name"
    },
    "route_sources": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/main_path_step"
      },
      "additionalProperties": {
        "$ref": "#/$defs/provider_name"
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_by", "generated_at", "source_queries", "confidence"],
      "properties": {
        "generated_by": {
          "enum": ["ai_discovery", "manual_replay"]
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_queries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "doi_prefixes",
        "domains",
        "domain_suffixes",
        "publisher_aliases",
        "crossref_publisher"
      ],
      "properties": {
        "primary": {
          "enum": ["doi_prefix", "domain", "publisher_alias"]
        },
        "doi_prefixes": {
          "$ref": "#/$defs/string_array"
        },
        "domains": {
          "$ref": "#/$defs/string_array"
        },
        "domain_suffixes": {
          "$ref": "#/$defs/string_array"
        },
        "publisher_aliases": {
          "$ref": "#/$defs/string_array"
        },
        "crossref_publisher": {
          "type": ["string", "null"]
        }
      }
    },
    "main_path": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/main_path_step"
      }
    },
    "route_contract": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/route_step_contract"
      }
    },
    "markdown_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "structure": {
          "$ref": "#/$defs/markdown_purpose_contract"
        },
        "table": {
          "$ref": "#/$defs/markdown_purpose_contract"
        },
        "formula": {
          "$ref": "#/$defs/markdown_purpose_contract"
        },
        "figure": {
          "$ref": "#/$defs/markdown_purpose_contract"
        },
        "supplementary": {
          "$ref": "#/$defs/markdown_purpose_contract"
        },
        "references": {
          "$ref": "#/$defs/markdown_purpose_contract"
        },
        "pdf_fallback": {
          "$ref": "#/$defs/markdown_purpose_contract"
        },
        "abstract_only": {
          "$ref": "#/$defs/markdown_purpose_contract"
        },
        "access_gate": {
          "$ref": "#/$defs/markdown_purpose_contract"
        },
        "empty_shell": {
          "$ref": "#/$defs/markdown_purpose_contract"
        }
      }
    },
    "success_criteria": {
      "type": "object",
      "additionalProperties": {
        "x-sync-back": true,
        "oneOf": [
          {"type": "null"},
          {"type": "object"},
          {"type": "array"}
        ]
      }
    },
    "asset_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["none", "body", "all"],
      "properties": {
        "none": {
          "$ref": "#/$defs/asset_kind_array"
        },
        "body": {
          "$ref": "#/$defs/asset_kind_array"
        },
        "all": {
          "$ref": "#/$defs/asset_kind_array"
        }
      }
    },
    "asset_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["figures"],
      "properties": {
        "figures": {
          "$ref": "#/$defs/figure_asset_contract"
        }
      }
    },
    "supplementary_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector", "url_pattern"],
      "properties": {
        "selector": {
          "type": ["string", "null"]
        },
        "url_pattern": {
          "type": ["string", "null"]
        }
      }
    },
    "abstract_only_strategy": {
      "enum": ["provider_managed", "metadata_only", "not_supported"]
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["env_requirements", "requires_playwright", "requires_browser_runtime"],
      "properties": {
        "env_requirements": {
          "$ref": "#/$defs/string_array"
        },
        "requires_playwright": {
          "type": "boolean"
        },
        "requires_browser_runtime": {
          "type": "boolean"
        },
        "ping_url": {
          "type": ["string", "null"],
          "format": "uri"
        }
      }
    },
    "fixtures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doi_samples", "discovery_proof"],
      "properties": {
        "doi_samples": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "structure",
            "table",
            "formula",
            "figure",
            "supplementary",
            "references",
            "pdf_fallback",
            "abstract_only",
            "access_gate",
            "empty_shell"
          ],
          "properties": {
            "structure": {
              "$ref": "#/$defs/doi_sample_required_doi"
            },
            "table": {
              "$ref": "#/$defs/doi_sample"
            },
            "formula": {
              "$ref": "#/$defs/doi_sample"
            },
            "figure": {
              "$ref": "#/$defs/doi_sample_required_doi"
            },
            "supplementary": {
              "$ref": "#/$defs/doi_sample"
            },
            "references": {
              "$ref": "#/$defs/doi_sample_required_doi"
            },
            "pdf_fallback": {
              "$ref": "#/$defs/doi_sample"
            },
            "abstract_only": {
              "$ref": "#/$defs/doi_sample"
            },
            "access_gate": {
              "$ref": "#/$defs/doi_sample"
            },
            "empty_shell": {
              "$ref": "#/$defs/doi_sample"
            }
          }
        },
        "discovery_proof": {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "formula", "supplementary"],
          "properties": {
            "table": {
              "$ref": "#/$defs/discovery_proof_entry"
            },
            "formula": {
              "$ref": "#/$defs/discovery_proof_entry"
            },
            "supplementary": {
              "$ref": "#/$defs/discovery_proof_entry"
            },
            "abstract_only": {
              "$ref": "#/$defs/discovery_proof_entry"
            },
            "access_gate": {
              "$ref": "#/$defs/discovery_proof_entry"
            },
            "empty_shell": {
              "$ref": "#/$defs/discovery_proof_entry"
            }
          }
        }
      }
    },
    "extra_fixtures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/extra_fixture"
      }
    },
    "extraction_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "datalayer_signal_set",
        "text_marker_signal_set",
        "front_matter",
        "asset_retry",
        "metadata_merge"
      ],
      "properties": {
        "datalayer_signal_set": {
          "x-sync-back": true,
          "$ref": "#/$defs/sync_back_value"
        },
        "text_marker_signal_set": {
          "x-sync-back": true,
          "$ref": "#/$defs/sync_back_value"
        },
        "front_matter": {
          "x-sync-back": true,
          "$ref": "#/$defs/sync_back_value"
        },
        "asset_retry": {
          "x-sync-back": true,
          "$ref": "#/$defs/sync_back_value"
        },
        "metadata_merge": {
          "x-sync-back": true,
          "$ref": "#/$defs/sync_back_value"
        }
      }
    },
    "owner_reuse_exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["owner", "reason"],
        "properties": {
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providers_md_capability_row", "changelog_summary"],
      "properties": {
        "providers_md_capability_row": {
          "type": "string",
          "minLength": 1
        },
        "changelog_summary": {
          "type": "string",
          "minLength": 1
        },
        "extraction_rules_summary": {
          "type": ["string", "null"]
        }
      }
    }
  },
  "$defs": {
    "provider_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "confidence": {
      "enum": ["high", "medium", "low"]
    },
    "main_path_step": {
      "enum": [
        "landing_html",
        "article_html",
        "xml",
        "pdf_fallback",
        "abstract_only",
        "metadata_only"
      ]
    },
    "doi": {
      "type": "string",
      "pattern": "^10\\.[^\\s/]+/.+"
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "route_step_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success_requires"],
      "properties": {
        "success_requires": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "reject_if_any": {
          "$ref": "#/$defs/string_array"
        },
        "min_body_chars": {
          "type": "integer",
          "minimum": 0
        },
        "min_body_sections": {
          "type": "integer",
          "minimum": 0
        },
        "require_pdf_magic": {
          "type": "boolean"
        },
        "reject_html_wrapper": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "markdown_purpose_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doi", "must_include", "must_not_include"],
      "properties": {
        "doi": {
          "$ref": "#/$defs/doi"
        },
        "must_include": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "must_not_include": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "must_match": {
          "$ref": "#/$defs/string_array"
        },
        "count_equals": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "asset_kind_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "figures",
          "body_tables",
          "formula_images",
          "supplementary",
          "multimedia"
        ]
      }
    },
    "figure_asset_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inline", "download", "purposes", "exception_reason"],
      "allOf": [
        {
          "if": {
            "anyOf": [
              {
                "properties": {
                  "inline": {
                    "const": "not_applicable"
                  }
                }
              },
              {
                "properties": {
                  "download": {
                    "const": "not_applicable"
                  }
                }
              }
            ]
          },
          "then": {
            "properties": {
              "exception_reason": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "else": {
            "properties": {
              "exception_reason": {
                "type": "null"
              }
            }
          }
        }
      ],
      "properties": {
        "inline": {
          "enum": ["body", "not_applicable"]
        },
        "download": {
          "enum": ["required", "not_applicable"]
        },
        "purposes": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "exception_reason": {
          "type": ["string", "null"]
        }
      }
    },
    "sync_back_value": {
      "oneOf": [
        {"type": "null"},
        {"type": "array"},
        {"type": "object"}
      ]
    },
    "doi_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doi",
        "evidence_url",
        "evidence_reason",
        "observed_signals",
        "confidence"
      ],
      "properties": {
        "doi": {
          "oneOf": [
            {"$ref": "#/$defs/doi"},
            {"type": "null"}
          ]
        },
        "evidence_url": {
          "type": "string",
          "format": "uri"
        },
        "evidence_reason": {
          "type": "string",
          "minLength": 1
        },
        "observed_signals": {
          "$ref": "#/$defs/string_array"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      },
      "if": {
        "properties": {
          "doi": {
            "$ref": "#/$defs/doi"
          }
        },
        "required": ["doi"]
      },
      "then": {
        "properties": {
          "observed_signals": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "doi_sample_required_doi": {
      "allOf": [
        {"$ref": "#/$defs/doi_sample"},
        {
          "type": "object",
          "properties": {
            "doi": {
              "$ref": "#/$defs/doi"
            }
          }
        }
      ]
    },
    "discovery_proof_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queries",
        "candidates",
        "selected_doi",
        "rejections",
        "exhausted",
        "evidence_summary"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "exhausted": {
                "const": false
              }
            },
            "required": ["exhausted"]
          },
          "then": {
            "properties": {
              "candidates": {
                "minItems": 1
              }
            }
          }
        }
      ],
      "properties": {
        "queries": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "candidates": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/doi"
          }
        },
        "selected_doi": {
          "oneOf": [
            {"$ref": "#/$defs/doi"},
            {"type": "null"}
          ]
        },
        "rejections": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/doi"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "exhausted": {
          "type": "boolean"
        },
        "evidence_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "extra_fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "purpose",
        "doi",
        "evidence_url",
        "evidence_reason",
        "observed_signals",
        "confidence"
      ],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "doi": {
          "$ref": "#/$defs/doi"
        },
        "evidence_url": {
          "type": "string",
          "format": "uri"
        },
        "evidence_reason": {
          "type": "string",
          "minLength": 1
        },
        "observed_signals": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "markdown_contract": {
          "$ref": "#/$defs/markdown_purpose_contract"
        }
      }
    }
  }
}
